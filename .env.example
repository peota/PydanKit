# OpenAI API Key (required)
OPENAI_API_KEY=sk-your-api-key-here

# Logfire Token (optional - for observability)
LOGFIRE_TOKEN=

# Model name (optional - defaults to openai:gpt-4o)
MODEL_NAME=openai:gpt-4o

# Debug mode (optional)
DEBUG=false

# Memory Configuration (optional - defaults work for most use cases)
# Enable/disable conversation memory (default: true)
# MEMORY_ENABLED=true

# Storage backend type: memory, file, or redis (default: memory)
# MEMORY_STORAGE_TYPE=memory

# File path for file-based storage (default: .memory)
# MEMORY_FILE_PATH=.memory

# Redis URL for redis storage (optional)
# MEMORY_REDIS_URL=redis://localhost:6379/0

# Maximum messages to keep per session (default: 100)
# MEMORY_MAX_MESSAGES=100

# Maximum tokens per session (optional - rough estimate)
# MEMORY_MAX_TOKENS=

# TTL in seconds for session expiration (optional)
# MEMORY_TTL_SECONDS=

# Auto-generate session_id from user_id (default: true)
# MEMORY_AUTO_SESSION=true
