# Display name for this agent. Branding shown on the dashboard, the browser tab,
# and the API/Swagger title. Purely cosmetic; defaults to "PydanKit".
AGENT_NAME=PydanKit

# Model name. Provider-agnostic - pick any model your account can access:
#   openai:gpt-4o | anthropic:claude-sonnet-4-5 | groq:llama-3.3-70b-versatile
#   deepseek:deepseek-chat | google:gemini-2.0-flash
MODEL_NAME=openai:gpt-4o

# Provide the API key for whichever provider MODEL_NAME uses (only one required).
OPENAI_API_KEY=sk-your-api-key-here
# ANTHROPIC_API_KEY=
# GROQ_API_KEY=
# DEEPSEEK_API_KEY=
# GEMINI_API_KEY=

# Max LLM requests per agent run (guards against a buggy tool looping). Default: 5
# AGENT_REQUEST_LIMIT=5

# Logfire Token (optional - for observability)
LOGFIRE_TOKEN=

# Debug mode (optional)
DEBUG=false

# --- API server (only used with the `serve` command) ---
# Allowed CORS origins (JSON list). Default is a localhost allowlist.
# With auth on, credentials are sent, so this must never be ["*"].
# CORS_ORIGINS=["http://localhost:8000"]
# Legacy single-shared-secret gate, only used when AUTH_ENABLED=false. When set,
# protected endpoints require a matching "X-API-Key" header. Superseded by per-user
# auth below when AUTH_ENABLED=true.
# API_KEY=
# Interactive API docs (/docs, /redoc, /openapi.json). Unset = follow DEBUG (on in dev,
# OFF in production). Set true/false to force.
# DOCS_ENABLED=

# --- Authentication (ADR 0001 / 0002) ---
# On by default. Set false to run the API open (no login).
AUTH_ENABLED=true
# Storage backend URL for users, tokens, and durable memory:
#   sqlite+aiosqlite:///./pydankit.db       (default, zero-config; light/local use)
#   sqlite+aiosqlite:////data/pydankit.db   (SQLite on a mounted volume — note FOUR
#                                            slashes = absolute /data path; use this on
#                                            Railway/Fly/Render + set RAILWAY_RUN_UID=0)
#   postgresql+asyncpg://user:pass@host/db  (cloud / multi-instance; needs [postgres])
DATABASE_URL=sqlite+aiosqlite:///./pydankit.db
# Legacy alias: when DATABASE_URL is unset, a SQLite URL is derived from this path.
# DATABASE_PATH=pydankit.db
# Env-seed the first admin on boot when no admin exists (no shell needed on the host).
# CHANGE THE PASSWORD before deploying anywhere public; rotate/clear it after first login.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-before-deploying
# Mark the session cookie Secure — MUST be true in any deployment served over HTTPS
# (Railway/Render/Fly all serve TLS). Leave false only for local http.
SESSION_COOKIE_SECURE=false
# Dashboard session cookie lifetime in days (sliding).
# SESSION_TTL_DAYS=7
# Login brute-force lockout (per username).
# LOGIN_MAX_ATTEMPTS=5
# LOGIN_LOCKOUT_SECONDS=300

# --- Memory ---
# Enable/disable conversation memory (default: true)
# MEMORY_ENABLED=true
# Conversation-memory backend. "auto" (default) follows DATABASE_URL: durable "sql"
# when a database is set, else in-process "memory". Force with "sql" / "memory"
# ("sqlite" = legacy alias for "sql").
# MEMORY_STORAGE_TYPE=auto
# Maximum messages to keep per session (default: 100)
# MEMORY_MAX_MESSAGES=100
# Auto-generate session_id from user_id (default: true)
# MEMORY_AUTO_SESSION=true
