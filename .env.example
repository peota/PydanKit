# Model name. Provider-agnostic - pick any model your account can access:
#   openai:gpt-4o | anthropic:claude-sonnet-4-5 | groq:llama-3.3-70b-versatile
#   deepseek:deepseek-chat | google:gemini-2.0-flash
MODEL_NAME=openai:gpt-4o

# Provide the API key for whichever provider MODEL_NAME uses (only one required).
OPENAI_API_KEY=sk-your-api-key-here
# ANTHROPIC_API_KEY=
# GROQ_API_KEY=
# DEEPSEEK_API_KEY=
# GEMINI_API_KEY=

# Max LLM requests per agent run (guards against a buggy tool looping). Default: 5
# AGENT_REQUEST_LIMIT=5

# Logfire Token (optional - for observability)
LOGFIRE_TOKEN=

# Debug mode (optional)
DEBUG=false

# --- API server (only used with the `serve` command) ---
# Allowed CORS origins (JSON list). Default is a localhost allowlist.
# CORS_ORIGINS=["http://localhost:8000"]
# Optional API key. When set, protected endpoints require an "X-API-Key" header.
# API_KEY=

# --- Memory (in-memory only; history is lost on restart) ---
# Enable/disable conversation memory (default: true)
# MEMORY_ENABLED=true
# Maximum messages to keep per session (default: 100)
# MEMORY_MAX_MESSAGES=100
# Auto-generate session_id from user_id (default: true)
# MEMORY_AUTO_SESSION=true
